# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── SECRETS — NEVER COMMIT ───────────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env*.local
# .env.example is intentionally NOT listed here — it is safe to commit

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage

# ── Next.js ───────────────────────────────────────────────────────────────────
/.next/
/out/

# ── Production ────────────────────────────────────────────────────────────────
/build

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Hardhat ───────────────────────────────────────────────────────────────────
/artifacts/
/cache/
/typechain-types/

.kiro/
