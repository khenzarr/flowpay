# ── FlowPay Environment Template ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
#
#   cp .env.example .env.local
#
# ─────────────────────────────────────────────────────────────────────────────

# Arc App Kit key (get from console.circle.com → Keys → Standard Key)
NEXT_PUBLIC_KIT_KEY=

# Your wallet address to receive the 0.5% protocol fee
NEXT_PUBLIC_FEE_RECIPIENT=

# ── FlowPay Daily Engine contract addresses ───────────────────────────────────
# Populated automatically after running the deploy script:
#   npx hardhat run scripts/deploy-gm-engine.ts --network arcTestnet
NEXT_PUBLIC_GM_CORE_ADDRESS=
NEXT_PUBLIC_GM_NFT_ADDRESS=

# Legacy single-contract fallback (optional)
NEXT_PUBLIC_GM_CONTRACT_ADDRESS=

# ── Deployer private key (Hardhat only) ───────────────────────────────────────
# Used ONLY for contract deployment via Hardhat.
# Paste here before deploying, remove after.
# This value is NEVER read by the Next.js frontend.
# NEVER commit this file.
DEPLOYER_PRIVATE_KEY=
